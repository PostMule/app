      "Bash(.venv/Scripts/pytest tests/unit/ -x -q)",
      "Bash(.venv/Scripts/pytest tests/unit/ -q)",
      "Bash(.venv/Scripts/pytest tests/unit/ -q --tb=no)",
      "Bash(.venv/Scripts/pytest tests/unit/ -q --tb=short)",
      "Bash(.venv/Scripts/pytest tests/unit/ -q --tb=long)",
      "Bash(.venv/Scripts/pytest tests/unit/ -q --tb=no --ignore=tests/unit/test_google_drive.py)",
      "Bash(.venv/Scripts/pytest tests/unit/ -q --tb=short --no-cov)",
      "Bash(.venv/Scripts/pytest --tb=short)",
      "Bash(.venv/Scripts/pytest tests/unit/ --tb=short -q)",
      "Bash(.venv/Scripts/pytest tests/unit/ -v --tb=short)",
      "Bash(.venv/Scripts/pip install:*)",
      "Bash(C:ClaudeCodeFilesClaudeCodePostMule.venvScriptspip list:*)",
      "Bash(gcloud version:*)",
      "Bash(export GCLOUD=\"/c/Users/openclaw0123/AppData/Local/Google/Cloud SDK/google-cloud-sdk/bin/gcloud\")",
      "Bash(\"$GCLOUD\" version:*)",
      "Bash(\"/c/Users/openclaw0123/AppData/Local/Google/Cloud SDK/google-cloud-sdk/bin/gcloud\" auth list --filter=\"status:ACTIVE\" --format=\"value\\(account\\)\" 2>/dev/null)",
      "Bash(bash scripts/dev_setup.sh)",
      "Bash(GCLOUD=\"/c/Users/openclaw0123/AppData/Local/Google/Cloud SDK/google-cloud-sdk/bin/gcloud\" bash scripts/dev_setup.sh)",
      "Bash(.venv/Scripts/python scripts/google_auth.py)",
      "Bash(PYTHONPATH=\"C:/ClaudeCodeFiles/ClaudeCode/PostMule\" .venv/Scripts/python scripts/google_auth.py)",
      "Bash(\"/c/Users/openclaw0123/AppData/Local/Google/Cloud SDK/google-cloud-sdk/bin/gcloud\" services list --project=postmule-app --enabled --format=\"value\\(config.name\\)\" 2>&1)",
      "Bash(PYTHONPATH=\"C:/ClaudeCodeFiles/ClaudeCode/PostMule\" .venv/Scripts/python -m postmule --dry-run)",
      "Bash(find C:/ClaudeCodeFiles/ClaudeCode/PostMule/postmule -name *.py)",
      "Bash(PYTHONPATH=\"C:/ClaudeCodeFiles/ClaudeCode/PostMule\" .venv/Scripts/python.exe -c \":*)",
      "Bash(set PYTHONPATH=C:ClaudeCodeFilesClaudeCodePostMule)",
      "Bash(PYTHONPATH=\"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\" python -m pytest \"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\\\\tests\" --tb=short -q --no-cov)",
      "Bash(PYTHONPATH=\"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\" python -m pytest \"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\\\\tests\" --cov=\"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\\\\postmule\" --cov-report=term-missing -q 2>&1)",
      "Bash(PYTHONPATH=\"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\" python -m pytest \"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\\\\tests\" --cov=\"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\\\\postmule\" --cov-report=term-missing --tb=no -v)",
      "Bash(PYTHONPATH=\"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\" python -m pytest \"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\\\\tests\" --cov=\"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\\\\postmule\" --cov-report=term-missing --tb=no)",
      "Bash(PYTHONPATH=\"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\" python -m pytest \"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\\\\tests\" --cov=postmule --cov-report=json --tb=no -q 2>&1)",
      "Bash(PYTHONPATH=\"C:\\\\ClaudeCodeFiles\\\\ClaudeCode\\\\PostMule\" python -m pytest tests/ --cov=postmule --cov-report=json -q)"
    ],
    "deny": [
      "Read(C:/Users/openclaw0123/PostMule/**)",
      "Read(**/credentials*.yaml)",
      "Read(**/config.yaml)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os; open(os.path.expanduser('~/.claude/pm-doc-session.txt'),'w').close()\" 2>/dev/null || true",
            "statusMessage": "Clearing doc-tracking file..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import sys,json,os; d=json.load(sys.stdin); fp=d.get('tool_input',{}).get('file_path','') or d.get('tool_response',{}).get('filePath',''); fp and open(os.path.expanduser('~/.claude/pm-doc-session.txt'),'a').write(fp+chr(10))\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "TRACKING=$(python -c \"import os; print(open(os.path.expanduser('~/.claude/pm-doc-session.txt')).read())\" 2>/dev/null || true); CHANGED=$(echo \"$TRACKING\" | tr '\\\\' '/' | sort -u); echo \"$CHANGED\" | grep -qi 'CLAUDE\\.md' && CLAUDE_OK=1 || CLAUDE_OK=0; echo \"$CHANGED\" | grep -qi 'mockup_dashboard\\.html' && MOCKUP_OK=1 || MOCKUP_OK=0; PY_CODE=$(echo \"$CHANGED\" | grep -iE '\\.py$' | grep -ivE '(/tests/|_test\\.py|__init__\\.py|conftest)' || true); PAGE_HTML=$(echo \"$CHANGED\" | grep -iE '/page\\.html$' || true); WARNINGS=''; [ -n \"$PY_CODE\" ] && [ \"$CLAUDE_OK\" -eq 0 ] && WARNINGS=\"${WARNINGS}CLAUDE.md may need updating (.py files changed). \"; [ -n \"$PAGE_HTML\" ] && [ \"$MOCKUP_OK\" -eq 0 ] && WARNINGS=\"${WARNINGS}mockup_dashboard.html may need updating (page.html changed). \"; [ -n \"$WARNINGS\" ] && python -c \"import json,sys; print(json.dumps({'systemMessage': 'Doc reminder: ' + sys.argv[1]}))\" \"$WARNINGS\" || true",
            "statusMessage": "Checking documentation coverage..."
          }
        ]
      }
    ]
  }
}
